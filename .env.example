# Airflow team-local settings
# Copy this file to .env and edit only the paths for the current PC.
# .env is intentionally ignored by Git.

# Required: team member's synced OneDrive root.
# Example: c:/Users/hong/OneDrive - 주식회사 도리당
ONEDRIVE_ROOT=c:/Users/민준/OneDrive - 주식회사 도리당

# Optional local folders. Keep these values if the folders are created as below.
LOCAL_DB_ROOT=c:/Local_DB
DORIDANG_ROOT=c:/Doridang
DOWN_DIR=e:/down
D_DOWN_DIR=e:/d_down

# Optional: Notion Calendar login/session for private morning briefing.
# Set real values only in local .env or Airflow environment, never in tracked files.
NOTION_EMAIL=
NOTION_PASSWORD=
# Host-local Notion Calendar cache collection only.
NOTION_CHROME_DEBUGGER=127.0.0.1:9223
NOTION_CALENDAR_PROFILE_DIR=/opt/airflow/chrome_profiles/notion_calendar
NOTION_CALENDAR_URL_TEMPLATE=https://calendar.notion.so/{year}/{month}
