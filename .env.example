# Airflow team-local settings
# Copy this file to .env and edit only the paths for the current PC.
# .env is intentionally ignored by Git.

# Required: team member's synced OneDrive root.
# Example: c:/Users/hong/OneDrive - 주식회사 도리당
ONEDRIVE_ROOT=c:/Users/민준/OneDrive - 주식회사 도리당

# Optional local folders. Keep these values if the folders are created as below.
LOCAL_DB_ROOT=c:/Local_DB
DORIDANG_ROOT=c:/Doridang
DOWN_DIR=e:/down
D_DOWN_DIR=e:/d_down

# Optional: Baemin macro PC role. Use top on the central PC and bottom on the second PC.
BAEMIN_MACRO_ROLE=

# Optional: OKPOS crawler login. Keep real values only in local .env.
OKPOS_ID=
OKPOS_PW=

# ToOrder 비밀번호의 단일 소스는 modules/transform/utility/account.py (get_pw) 이다.
# account.py 에 있는 계정(예: doridang15)은 account.py 값이 항상 최우선이라
# 아래 env/Airflow Variable 로는 override 되지 않는다(스테일 값 마스킹 방지).
# 이 env 는 account.py 에 없는 계정에만 폴백으로 쓰인다.
# TOORDER_PW=
# TOORDER_PW_DORIDANG15=
